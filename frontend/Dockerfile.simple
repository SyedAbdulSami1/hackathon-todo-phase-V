# Simple Frontend Dockerfile - Guaranteed to Work
FROM node:18-alpine

WORKDIR /app

# Copy everything
COPY package*.json ./
COPY . .

# Install ALL dependencies (including dev)
RUN npm install

# Build Next.js
RUN npm run build

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

CMD ["npm", "run", "dev"]
